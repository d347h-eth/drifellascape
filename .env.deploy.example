# Drifellascape deploy environment
# Copy to `.env.deploy` on the server and keep secrets out of git.

## Shared edge
PUBLIC_EDGE_NETWORK=public-edge

## Backend
BACKEND_PORT=3000
BACKEND_REFRESH_MS=30000
BACKEND_DEBUG=
BACKEND_METRICS_ENABLED=true
BACKEND_METRICS_PORT=42840

## Worker
WORKER_SYNC_INTERVAL_MS=30000
MARKET_EVENT_RECENT_PAGES=2
MARKET_EVENT_BACKFILL_PAGES=5
HELIUS_KEY=
OWNERSHIP_SYNC_INTERVAL_MS=600000
WORKER_METRICS_ENABLED=true
WORKER_METRICS_PORT=42841

## Shared Magic Eden/Helius fetch timeout and retry policy
COMMON_HTTP_FETCH_TIMEOUT_MS=30000
COMMON_HTTP_FETCH_RETRY_MAX_ATTEMPTS=3
COMMON_HTTP_FETCH_RETRY_BASE_DELAY_MS=2000
COMMON_HTTP_FETCH_RETRY_MAX_DELAY_MS=8000

## Private Grafana exposure
# Bind Grafana only on the server WireGuard IP reachable from the admin machine.
OBSERVABILITY_GRAFANA_HOST_BIND_IP=10.77.0.1
OBSERVABILITY_GRAFANA_HOST_BIND_PORT=42835
OBSERVABILITY_GRAFANA_ADMIN_USER=admin
OBSERVABILITY_GRAFANA_ADMIN_PASSWORD=change-me
