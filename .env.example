# Drifellascape local/deploy environment
# Copy to `.env` for local dev and Docker Compose:
#   cp .env.example .env
#
# Local scripts load `.env` as defaults; already-set env vars take precedence.
# Keep secrets out of git. `.env` is ignored.

## Backend
# Backend HTTP port.
BACKEND_PORT=3000

# Backend polling interval for active listing version changes, in ms. Minimum: 5000.
BACKEND_REFRESH_MS=30000

# Set to 1 to include anchorDebug in search responses.
BACKEND_DEBUG=

## Backend observability
# Enables a Prometheus scrape endpoint on /metrics and /healthz.
BACKEND_METRICS_ENABLED=true
BACKEND_METRICS_HOST=127.0.0.1
BACKEND_METRICS_PORT=42840

## Worker
# Main worker loop interval, in ms. Minimum: 5000.
WORKER_SYNC_INTERVAL_MS=30000

# Magic Eden market event feed pages sampled each worker cycle. Range: 0..10.
MARKET_EVENT_RECENT_PAGES=2

# Magic Eden historical activity backfill pages processed each worker cycle. Range: 0..25.
MARKET_EVENT_BACKFILL_PAGES=5

# Optional Helius key for ownership snapshots. Leave blank to disable ownership sync.
HELIUS_KEY=

# Ownership snapshot interval, in ms. Default: 10 minutes. Minimum: 60000.
OWNERSHIP_SYNC_INTERVAL_MS=600000

## Worker observability and external API resilience
# Enables a Prometheus scrape endpoint on /metrics and /healthz.
WORKER_METRICS_ENABLED=true
WORKER_METRICS_HOST=127.0.0.1
WORKER_METRICS_PORT=42841

# Shared Magic Eden/Helius fetch timeout and retry policy.
# Retries are only scheduled for HTTP 429 and 5xx responses or thrown fetch errors.
COMMON_HTTP_FETCH_TIMEOUT_MS=30000
COMMON_HTTP_FETCH_RETRY_MAX_ATTEMPTS=3
COMMON_HTTP_FETCH_RETRY_BASE_DELAY_MS=2000
COMMON_HTTP_FETCH_RETRY_MAX_DELAY_MS=8000

## Observability stack
# Local Grafana defaults to http://127.0.0.1:42835.
OBSERVABILITY_GRAFANA_ADMIN_USER=admin
OBSERVABILITY_GRAFANA_ADMIN_PASSWORD=admin

## Frontend
# Browser API base. Empty means same-origin in built frontend and Vite dev proxy locally.
VITE_API_BASE=

# Listings poll interval in the frontend, in ms. Runtime minimum: 5000.
VITE_POLL_MS=30000

## Frontend E2E
# Set when running Playwright against an already-running frontend.
FRONTEND_E2E_BASE_URL=

# Set to 1 to keep screenshots/video/trace for successful Playwright runs.
FRONTEND_E2E_PERSIST_SUCCESS_ARTIFACTS=
