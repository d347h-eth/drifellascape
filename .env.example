# Drifellascape local/deploy environment
# Copy to `.env` for local dev and Docker Compose:
#   cp .env.example .env
#
# Local scripts load `.env` as defaults; already-set env vars take precedence.
# Keep secrets out of git. `.env` is ignored.

## Backend
# Backend HTTP port.
DRIFELLASCAPE_PORT=3000

# Backend polling interval for active listing version changes, in ms. Minimum: 5000.
DRIFELLASCAPE_BACKEND_REFRESH_MS=30000

# Set to 1 to include anchorDebug in search responses.
DRIFELLASCAPE_DEBUG=

## Worker
# Main worker loop interval, in ms. Minimum: 5000.
DRIFELLASCAPE_SYNC_INTERVAL_MS=30000

# Magic Eden market event feed pages sampled each worker cycle. Range: 0..10.
DRIFELLASCAPE_MARKET_EVENT_RECENT_PAGES=2

# Magic Eden historical activity backfill pages processed each worker cycle. Range: 0..25.
DRIFELLASCAPE_MARKET_EVENT_BACKFILL_PAGES=5

# Optional Helius key for ownership snapshots. Leave blank to disable ownership sync.
HELIUS_KEY=

# Alias for HELIUS_KEY if preferred by deployment config.
DRIFELLASCAPE_HELIUS_KEY=

# Ownership snapshot interval, in ms. Default: 10 minutes. Minimum: 60000.
DRIFELLASCAPE_OWNERSHIP_SYNC_INTERVAL_MS=600000

## Frontend
# Browser API base. Empty means same-origin in built frontend and Vite dev proxy locally.
VITE_API_BASE=

# Listings poll interval in the frontend, in ms. Runtime minimum: 5000.
VITE_POLL_MS=30000

## Frontend E2E
# Set when running Playwright against an already-running frontend.
DRIFELLASCAPE_E2E_BASE_URL=

# Set to 1 to keep screenshots/video/trace for successful Playwright runs.
DRIFELLASCAPE_E2E_PERSIST_SUCCESS_ARTIFACTS=
